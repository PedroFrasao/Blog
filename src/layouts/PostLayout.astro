---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
}

const { title, description, pubDate, updatedDate, tags } = Astro.props;

const dataFormatada = pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
---
<BaseLayout title={`${title} — artigos`} description={description}>
  <div class="wrap">
    <header class="article-header">
      <p class="post-meta">
        {dataFormatada}
        {tags.map((tag) => <span class="tag"> · #{tag}</span>)}
      </p>
      <h1>{title}</h1>
      <p class="desc">{description}</p>
    </header>

    <article class="prose">
      <slot />
    </article>

    <Giscus />
  </div>
</BaseLayout>
