---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Artigos sobre eletrônica e sistemas embarcados.',
} = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Aplica o tema salvo (claro/escuro/sistema) antes do primeiro paint -->
    <script is:inline>
      (function () {
        const salvo = localStorage.getItem('theme') || 'system';
        const efetivo =
          salvo === 'system'
            ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
            : salvo;
        document.documentElement.setAttribute('data-theme', efetivo);
      })();
    </script>

    <!--
      Cloudflare Web Analytics
      Pegue o seu token em: Cloudflare Dashboard > Analytics > Web Analytics
      e cole aqui no lugar de "SEU_TOKEN_AQUI".
    -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "SEU_TOKEN_AQUI"}'
    ></script>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
