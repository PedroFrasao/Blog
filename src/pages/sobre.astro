---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Sobre — artigos.dev">
  <div class="wrap">
    <section class="hero">
      <span class="eyebrow">// sobre</span>
      <h1>Quem escreve aqui</h1>
      <p>
        Sou da área de eletrônica / sistemas embarcados e uso este espaço
        para registrar projetos, aprendizados e soluções de problemas que
        encontro no caminho. Edite este texto em
        <code>src/pages/sobre.astro</code> e conte sua história.
      </p>
    </section>
  </div>
</BaseLayout>
