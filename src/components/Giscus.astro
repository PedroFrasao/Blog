---
// Comentários via Giscus (usa o GitHub Discussions do seu repositório).
// 1. Vá em https://giscus.app, conecte seu repositório (precisa ser público
//    e ter o app "giscus" instalado + Discussions habilitado).
// 2. O site giscus.app gera os valores abaixo (data-repo-id, data-category-id etc).
//    Copie e cole os seus valores aqui.
---
<div class="comments-section">
  <span class="eyebrow">// comentários</span>
  <script
    src="https://giscus.app/client.js"
    data-repo="SEU-USUARIO/SEU-REPO"
    data-repo-id="TROQUE_PELO_REPO_ID"
    data-category="Comentários"
    data-category-id="TROQUE_PELO_CATEGORY_ID"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="dark_dimmed"
    data-lang="pt"
    crossorigin="anonymous"
    async
  ></script>
</div>
